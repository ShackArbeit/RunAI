{
  "name": "api",
  "private": true,
  "scripts": {
    "dev": "set PYTHONDONTWRITEBYTECODE=1 && python -B -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "set PYTHONDONTWRITEBYTECODE=1 && python -B -c \"import app.main\"",
    "lint": "set PYTHONDONTWRITEBYTECODE=1 && python -B -m ruff check .",
    "test": "set PYTHONDONTWRITEBYTECODE=1 && python -B -m pytest",
    "migrate": "set PYTHONDONTWRITEBYTECODE=1 && python -B -c \"from alembic.config import main; main(argv=['upgrade','head'])\""
  }
}
